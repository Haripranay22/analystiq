# Streamlit Community Cloud secrets template
# In the Streamlit Cloud dashboard: App Settings → Secrets → paste these values
# Do NOT commit the real secrets.toml to git (it's in .gitignore)

OPENAI_API_KEY = "sk-your-key-here"
OPENAI_MODEL   = "gpt-4o-mini"
DATABASE_URL   = "postgresql://user:password@host:5432/analystiq"
