# Streamlit Community Cloud secrets template
# In the Streamlit Cloud dashboard: App Settings → Secrets → paste these values
# Do NOT commit the real secrets.toml to git (it's in .gitignore)

OPENAI_API_KEY  = "sk-your-key-here"
OPENAI_MODEL    = "gpt-4o-mini"
DATABASE_URL    = "postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/analystiq?sslmode=require"
DATABASE_URL_RO = "postgresql://analystiq_ro:password@ep-xxx.us-east-1.aws.neon.tech/analystiq?sslmode=require"
API_URL         = "https://your-app.up.railway.app"
