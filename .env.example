# AnalystIQ Environment Variables
# Local dev: copy to .env and fill in values
# Streamlit Cloud: paste into App Settings → Secrets (use secrets.toml.example format)
# NEVER commit .env or secrets.toml to git

# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# PostgreSQL
# DATABASE_URL_RO is optional — used by /execute for read-only safety
# Create role: CREATE ROLE analystiq_ro LOGIN PASSWORD '...' + GRANT SELECT
# Local:  postgresql://postgres:password@localhost:5432/analystiq
# Neon:   postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/analystiq?sslmode=require
DATABASE_URL=postgresql://postgres:your-password-here@localhost:5432/analystiq
DATABASE_URL_RO=postgresql://analystiq_ro:your-password-here@localhost:5432/analystiq

# Backend URL — where the FastAPI server is running
# Local dev: http://127.0.0.1:8000
# Cloud (Railway): https://your-app.up.railway.app
API_URL=http://127.0.0.1:8000
